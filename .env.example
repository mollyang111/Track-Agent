# Local Ollama model (must be pulled first: ollama pull deepseek-r1:7b)
OLLAMA_MODEL=deepseek-r1:7b
OLLAMA_HOST=http://localhost:11434

# How often to poll for changes (seconds)
POLL_INTERVAL_SECONDS=30

# Optional: only watch a specific Google Drive folder ID
# Leave blank to watch your entire Drive
WATCH_FOLDER_ID= 

# Optional: webhook URL to POST change summaries to
WEBHOOK_URL=

# Optional: shell command to run on each change
# Environment variables passed: DRIVE_FILE_ID, DRIVE_FILE_NAME, DRIVE_SUMMARY, DRIVE_LINK
CUSTOM_SCRIPT=

# Log file path
LOG_FILE=state/changes.log

# MySQL database connection
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=6884525molly
MYSQL_DATABASE=track_agent
